{
  "name": "lobster-pet",
  "version": "1.0.0",
  "description": "Lobster Pet - 小龙虾桌面宠物助手",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"node scripts/build-electron.mjs && wait-on http://localhost:5173 && electron .\"",
    "build": "node scripts/build-electron.mjs && vite build && electron-builder",
    "preview": "node scripts/build-electron.mjs && vite build && electron .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.lobster.pet",
    "productName": "Lobster Pet",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
